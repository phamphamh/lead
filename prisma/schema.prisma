// Prisma schema for "lead".
// Docs: https://pris.ly/d/prisma-schema
//
// Auth is handled by Better Auth (GitHub OAuth). The User/Session/Account/
// Verification models below are the Better Auth core schema; the GitHub OAuth
// access token lives on `Account.accessToken` and is what we use to read the
// customer's repos. Project ownership is a real `userId` relation.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: the connection URL lives in prisma.config.ts (CLI) and is passed
  // to PrismaClient via a driver adapter at runtime (see lib/db.ts).
}

/* --- Better Auth core models ------------------------------------------ */

/// An authenticated user (identity comes from GitHub via Better Auth).
model User {
  id            String  @id
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?

  sessions Session[]
  accounts Account[]
  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user")
}

/// A Better Auth session.
model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session")
}

/// A linked OAuth account. For GitHub, `accessToken` is the token we use to
/// call the GitHub API on the user's behalf. Never log this value.
model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("account")
}

/// Better Auth verification tokens (email, etc.).
model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("verification")
}

/* --- domain models ---------------------------------------------------- */

/// Which conversion surface an experiment targets.
enum Surface {
  LANDING
  ONBOARDING
  PAYWALL
}

enum ExperimentStatus {
  DRAFT
  RUNNING
  COMPLETED
  ABANDONED
}

enum VariantKind {
  CONTROL
  TREATMENT
}

/// A free public landing-page audit (the lead magnet). Every run is a lead:
/// the visitor's URL — and email, when provided — captured alongside the
/// Claude-generated result.
model Audit {
  id        String   @id @default(cuid())
  url       String?
  email     String?
  /// 0..100 overall CRO score (mirrors result.score for cheap querying).
  score     Int
  /// Full AuditResult JSON (see lib/audit/types.ts).
  result    Json
  /// 'url' (crawled) | 'text' (pasted fallback).
  source    String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// A customer's connected GitHub repository that we analyze and optimize.
model Project {
  id           String  @id @default(cuid())
  name         String
  repoFullName String // e.g. "acme/web"
  repoUrl      String
  githubRepoId String? // GitHub's numeric repo id, stored as string
  defaultBranch String @default("main")
  private      Boolean @default(false)
  // Public key the tracking SDK sends with every event batch (see /api/ingest).
  // Nullable so projects created before tracking existed backfill lazily.
  sdkKey       String? @unique
  // Forward-compat: set once a GitHub App is installed for PR-writing.
  githubInstallationId String?

  // Ownership.
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  experiments Experiment[]
  events      Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, repoFullName])
  @@index([userId])
}

/// A single A/B test the orchestrator runs on a project's surface.
model Experiment {
  id         String           @id @default(cuid())
  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  surface    Surface
  status     ExperimentStatus @default(DRAFT)
  hypothesis String?

  variants Variant[]

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
  @@index([status])
}

/// A variant within an experiment (control or a generated treatment).
model Variant {
  id           String      @id @default(cuid())
  experiment   Experiment  @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  experimentId String
  kind         VariantKind
  label        String
  // Reference to the change the agent produced (e.g. a PR / branch / patch ref).
  changeRef    String?

  // Lightweight rollup metrics; detailed events live in the Event table.
  impressions Int @default(0)
  conversions Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([experimentId])
}

/// What a visitor did, as emitted by the tracking SDK on the customer's site.
enum EventType {
  PAGEVIEW   // a page was viewed
  CLICK      // a link/button (or [data-lead-event]) was clicked
  CONVERSION // a goal was reached (signup, checkout, [data-lead-conversion])
  EXPOSURE   // a visitor was shown a specific experiment variant
}

/// A single raw tracking event. High-volume, append-only. Aggregations for the
/// dashboard live in lib/metrics.ts; per-variant rollups live on Variant.
model Event {
  id        String    @id @default(cuid())
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  type      EventType

  // Anonymous, first-party visitor + session identifiers (no PII).
  visitorId String
  sessionId String?

  // Context. `name` is the click label / goal name; experiment+variant are set
  // on EXPOSURE/CONVERSION so we can attribute conversions to a variant.
  name         String?
  path         String?
  referrer     String?
  experimentId String?
  variantId    String?
  meta         Json?

  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([projectId, type, createdAt])
  @@index([projectId, visitorId])
}
